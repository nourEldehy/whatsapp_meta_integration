<odoo>
    <record id="send_whatsapp_wizard_view_form" model="ir.ui.view">
        <field name="name">send.whatsapp.wizard.form</field>
        <field name="model">send.whatsapp.wizard</field>
        <field name="arch" type="xml">
            <form string="Send WhatsApp Message">
                <group>
                    <field name="partner_id"/>
                    <field name="template_id" options="{'no_create': True, 'no_open': True}"/>
                </group>
                <field name="variable_ids" nolabel="1">
                    <tree editable="bottom">
                        <field name="sequence" invisible="1"/>
                        <field name="name" readonly="1"/>
                        <field name="value" placeholder="Enter value here..."/>
                    </tree>
                </field>
                <footer>
                    <button name="action_send_message" string="Send" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>